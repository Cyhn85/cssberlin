{
  "name": "cssberlin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf:build": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "cf:dev": "wrangler pages dev .worker-next --compatibility-flag=nodejs_compat",
    "cf:deploy": "wrangler pages deploy .open-next --project-name=cssberlin",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.1.1",
    "@types/node": "^22.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pg": "^8.20.0",
    "prisma": "^5.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.80.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
