# Environment Variables Template
# Copy this to .env and fill in your values

# Database Connection
# For local development with Neon PostgreSQL:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Example:
# DATABASE_URL="postgresql://myuser:mypassword@ep-cool-darkness-123456.eu-central-1.aws.neon.tech/cssberlin?sslmode=require"

# For Cloudflare Pages deployment:
# Add this as a secret environment variable in Cloudflare Dashboard
# Workers & Pages → cssberlin → Settings → Environment Variables
