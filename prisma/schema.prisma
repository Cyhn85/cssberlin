// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Category with self-referencing for subcategories
model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  parentId  String?

  // Self-referencing relationship
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryHierarchy")

  // Products in this category
  products  Product[]

  @@map("Category")
}

// Product Model
model Product {
  id            String       @id @default(uuid())
  brand         String
  name          String
  slug          String       @unique
  description   String?
  size          String
  condition     String       // "Neu", "Neuwertig", "Sehr gut", "Gut"
  price         Float
  newPrice      Float        @default(0)
  carbonSaved   Float        // kg CO2
  tier          String       // "champion", "profi", "fortgeschritten", "einsteiger", "premium", "designer", "vintage", "standard"
  images        String       // JSON array of image URLs
  sale          Boolean      @default(false)
  featured      Boolean      @default(false)
  isActive      Boolean      @default(true)

  // Category relationship
  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Additional metadata
  material      String?
  color         String?
  gender        String?      // "female", "male", "kids", "unisex"

  // Vinted Integration
  vintedId      String?      @unique  // Vinted product ID
  vintedUrl     String?               // Direct link to Vinted listing

  // SEO & Analytics
  views         Int          @default(0)
  wishlistCount Int          @default(0)

  // Timestamps
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("Product")
}
